APP_NAME=EduKitt
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Optional table prefix. Applied to every table (including Laravel's
# `migrations` repo). Leave blank to disable. Recommended on shared
# hosts where you may share a single database with other apps.
DB_PREFIX=ek_

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

CACHE_STORE=database
# CACHE_PREFIX=

# -----------------------------------------------------------------------------
# Queue (Redis recommended in production — run a worker continuously)
# -----------------------------------------------------------------------------
# Laravel Horizon is installed: queues use Redis when QUEUE_CONNECTION=redis.
# Local: start Redis, set QUEUE_CONNECTION=redis, then run `php artisan horizon`
#   (leave that terminal open) or see deployment/supervisor/laravel-horizon.conf.example
# Alternate without Horizon: `php artisan queue:work redis --queue=default,emails,ai,ai-gemini`
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Separate DB index for cache/sessions vs queue payload if desired (optional)
# CACHE_STORE=redis
# SESSION_CONNECTION=redis

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
